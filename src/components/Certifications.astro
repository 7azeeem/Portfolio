---
import ExternalLink from "./icons/ExternalLink.astro"
import certifications from "@/data/certifications.json"
---

<div class="grid gap-5 md:grid-cols-2">
  {
    certifications.map((cert) => (
      <article class="group relative overflow-hidden rounded-lg border border-gray-200/80 bg-white/75 p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-yellow-400/40 hover:shadow-xl hover:shadow-yellow-500/10 dark:border-white/10 dark:bg-gray-900/65">
        <div
          class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${cert.accent}`}
          aria-hidden="true"
        />
        <div
          class={`pointer-events-none absolute inset-0 bg-gradient-to-br ${cert.accent} opacity-0 transition-opacity duration-300 group-hover:opacity-100`}
          aria-hidden="true"
        />

        <div class="relative flex h-full flex-col gap-4">
          <div class="flex items-start gap-4">
            <div class="flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-gray-200 bg-gray-50 p-2 shadow-inner dark:border-white/10 dark:bg-gray-950/70">
              {cert.logo ? (
                <img
                  src={cert.logo}
                  alt={`${cert.issuer} logo`}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
              ) : (
                <span class="text-sm font-bold text-gray-700 dark:text-gray-200">
                  {cert.logoText}
                </span>
              )}
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-yellow-700 dark:text-yellow-300">
                {cert.issuer}
              </p>
              <h3 class="mt-1 text-lg font-bold leading-snug text-gray-900 dark:text-white">
                {cert.title}
              </h3>
            </div>
          </div>

          {cert.image && (
            <div class="flex h-44 items-center justify-center overflow-hidden rounded-md border border-gray-200/80 bg-gray-50/90 p-3 transition duration-300 group-hover:border-yellow-400/30 dark:border-white/10 dark:bg-gray-950/60 sm:h-52">
              <img
                src={cert.image}
                alt={`${cert.title} certificate badge`}
                class="max-h-full max-w-full object-contain transition duration-500 group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          )}

          <div class="flex flex-wrap gap-2">
            {cert.issued && (
              <span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-2.5 py-1 text-xs font-medium text-emerald-700 dark:text-emerald-300">
                Issued {cert.issued}
              </span>
            )}
            {cert.expires && (
              <span class="rounded-full border border-amber-500/20 bg-amber-500/10 px-2.5 py-1 text-xs font-medium text-amber-700 dark:text-amber-300">
                Expires {cert.expires}
              </span>
            )}
          </div>

          <p class="text-sm leading-6 text-gray-700 dark:text-gray-300">
            {cert.description}
          </p>

          <div class="mt-auto flex flex-col gap-3 border-t border-gray-200 pt-4 dark:border-white/10">
            {cert.credentialId && (
              <p class="break-all font-mono text-[11px] leading-5 text-gray-500 dark:text-gray-500">
                Credential ID: {cert.credentialId}
              </p>
            )}
            <a
              href={cert.credentialUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex max-w-fit items-center gap-2 rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm font-medium text-gray-800 transition hover:border-gray-900 hover:bg-gray-900 hover:text-white focus:outline-none focus-visible:ring focus-visible:ring-yellow-500/80 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:hover:border-yellow-400/60"
            >
              <ExternalLink class="size-4" />
              Show credential
            </a>
          </div>
        </div>
      </article>
    ))
  }
</div>
