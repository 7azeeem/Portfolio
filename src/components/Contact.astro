---
import ContactField from "@/components/ContactField.astro"
import MailIcon from "@/components/icons/Mail.astro"
---

<div class="mx-auto max-w-3xl">
  <form
    id="contact-form"
    class="rounded-2xl border border-gray-300/70 bg-white/55 p-5 shadow-xl shadow-black/5 ring-1 ring-white/50 backdrop-blur-sm transition duration-300 hover:border-yellow-400/30 hover:shadow-[0_20px_70px_-25px_rgba(251,191,36,0.28)] dark:border-white/10 dark:bg-gray-900/45 dark:shadow-black/20 dark:ring-white/5 sm:p-6"
    novalidate
  >
    <div class="grid gap-5 sm:grid-cols-2">
      <ContactField
        id="first-name"
        name="first_name"
        label="First Name"
        autocomplete="given-name"
        placeholder="Adel"
      />
      <ContactField
        id="last-name"
        name="last_name"
        label="Last Name"
        autocomplete="family-name"
        placeholder="Ashraf"
      />
    </div>

    <div class="mt-5">
      <ContactField
        id="email"
        name="email"
        label="Email Address"
        type="email"
        autocomplete="email"
        placeholder="you@example.com"
      />
    </div>

    <div class="mt-5">
      <ContactField
        id="message"
        name="message"
        label="Message"
        textarea
        minLength={10}
        placeholder="Tell me about your project or opportunity..."
      />
    </div>

    <button
      type="submit"
      class="group mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-yellow-400/70 bg-yellow-400 px-5 py-3 text-base font-semibold text-gray-950 shadow-lg shadow-yellow-500/10 transition duration-200 hover:-translate-y-0.5 hover:bg-yellow-300 hover:shadow-[0_18px_45px_-18px_rgba(251,191,36,0.8)] focus:outline-none focus-visible:ring focus-visible:ring-yellow-300 focus-visible:ring-offset-2 focus-visible:ring-offset-white disabled:cursor-not-allowed disabled:opacity-70 disabled:hover:translate-y-0 dark:border-yellow-300/70 dark:focus-visible:ring-offset-gray-950 sm:w-auto"
      data-submit-button
    >
      <MailIcon class="size-5 transition duration-200 group-hover:translate-x-0.5" />
      <span data-submit-text>Send Message</span>
    </button>
  </form>
</div>

<div
  id="contact-toast"
  class="fixed bottom-5 left-1/2 z-50 hidden w-[calc(100%-2rem)] max-w-sm -translate-x-1/2 rounded-xl border px-4 py-3 text-sm font-medium shadow-2xl backdrop-blur-md transition sm:bottom-8"
  role="status"
  aria-live="polite"
></div>

<script>
  import emailjs from "@emailjs/browser"

  const getEmailConfig = () => ({
    serviceId: import.meta.env.PUBLIC_EMAILJS_SERVICE_ID?.trim() ?? "",
    templateId: import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID?.trim() ?? "",
    publicKey: import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY?.trim() ?? "",
  })

  let emailjsInitialized = false

  const ensureEmailjsReady = () => {
    const config = getEmailConfig()
    const missingKeys = Object.entries(config)
      .filter(([, value]) => !value)
      .map(([key]) => key)

    if (missingKeys.length > 0) {
      return { config, isReady: false }
    }

    if (!emailjsInitialized) {
      emailjs.init({ publicKey: config.publicKey })
      emailjsInitialized = true
    }

    return { config, isReady: true }
  }

  const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
  const minMessageLength = 10

  const setupContactForm = () => {
    const form = document.querySelector<HTMLFormElement>("#contact-form")
    const toast = document.querySelector<HTMLDivElement>("#contact-toast")

    if (!form || !toast) return
    if (form.dataset.contactReady === "true") return
    form.dataset.contactReady = "true"

    const submitButton = form.querySelector<HTMLButtonElement>("[data-submit-button]")
    const submitText = form.querySelector<HTMLElement>("[data-submit-text]")

    const setError = (name: string, message = "") => {
      const error = form.querySelector<HTMLElement>(`[data-error-for="${name}"]`)
      const field = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null

      if (!error || !field) return

      error.textContent = message
      error.classList.toggle("hidden", !message)
      field.setAttribute("aria-invalid", message ? "true" : "false")
    }

    const showToast = (message: string, type: "success" | "error") => {
      toast.textContent = message
      toast.className =
        "fixed bottom-5 left-1/2 z-50 w-[calc(100%-2rem)] max-w-sm -translate-x-1/2 rounded-xl border px-4 py-3 text-sm font-medium shadow-2xl backdrop-blur-md transition sm:bottom-8"
      toast.classList.add(
        ...(type === "success"
          ? [
              "border-yellow-400/40",
              "bg-gray-950/90",
              "text-white",
              "shadow-yellow-500/10",
            ]
          : [
              "border-red-400/40",
              "bg-red-950/90",
              "text-white",
              "shadow-red-500/10",
            ]),
      )

      window.setTimeout(() => {
        toast.classList.add("hidden")
      }, 4200)
    }

    const validate = () => {
      const formData = new FormData(form)
      const values = {
        first_name: String(formData.get("first_name") ?? "").trim(),
        last_name: String(formData.get("last_name") ?? "").trim(),
        email: String(formData.get("email") ?? "").trim(),
        message: String(formData.get("message") ?? "").trim(),
      }

      setError("first_name")
      setError("last_name")
      setError("email")
      setError("message")

      let isValid = true

      if (!values.first_name) {
        setError("first_name", "First name is required.")
        isValid = false
      }

      if (!values.last_name) {
        setError("last_name", "Last name is required.")
        isValid = false
      }

      if (!values.email) {
        setError("email", "Email address is required.")
        isValid = false
      } else if (!emailPattern.test(values.email)) {
        setError("email", "Enter a valid email address.")
        isValid = false
      }

      if (!values.message) {
        setError("message", "Message is required.")
        isValid = false
      } else if (values.message.length < minMessageLength) {
        setError("message", `Message must be at least ${minMessageLength} characters.`)
        isValid = false
      }

      return { isValid, values }
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault()

      const { isValid, values } = validate()
      if (!isValid) return

      const { config, isReady } = ensureEmailjsReady()

      if (!isReady) {
        showToast("Email service is not configured yet.", "error")
        return
      }

      submitButton?.setAttribute("disabled", "true")
      if (submitText) submitText.textContent = "Sending..."

      try {
        await emailjs.send(config.serviceId, config.templateId, values, {
          publicKey: config.publicKey,
        })

        form.reset()
        showToast("Message sent successfully. Thank you!", "success")
      } catch {
        showToast("Something went wrong. Please try again.", "error")
      } finally {
        submitButton?.removeAttribute("disabled")
        if (submitText) submitText.textContent = "Send Message"
      }
    })
  }

  document.addEventListener("astro:page-load", setupContactForm)
  setupContactForm()
</script>
